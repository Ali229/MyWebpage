[
  {
    "title": "Deploy reqarr server",
    "command": "cd /opt/media-stack && docker compose up -d --build reqarr"
  },
  {
    "title": "Update Docker containers and Dockcheck itself",
    "command": "/opt/media-stack/dockcheck.sh -y -u -p"
  },
  {
    "title": "Upgrade all Windows packages",
    "command": "powershell -NoProfile -Command \"Start-Process powershell -Verb RunAs -ArgumentList '-NoProfile -NoExit -Command winget upgrade --all'\""
  }
]
